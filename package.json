{
  "name": "appshot",
  "version": "0.0.1",
  "description": "A local-first CLI for managing app store screenshots.",
  "type": "module",
  "bin": {
    "appshot": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "appshot": "tsx src/cli.ts",
    "dev": "tsx watch --clear-screen=false src/cli.ts dev playground --no-open",
    "build": "npm run build:cli && npm run build:ui",
    "build:cli": "tsup",
    "build:ui": "vite build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "commander": "latest",
    "open": "latest",
    "shadcn": "^4.13.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
